<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.UIUCPlanBuilder">

        <!-- Home screen with bottom navigation -->
        <activity
            android:name=".HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.UIUCPlanBuilder.NoActionBar" />

        <!-- Launcher screen (Compose) -->
        <activity
            android:name=".WelcomeActivity"
            android:exported="true"
            android:theme="@style/Theme.UIUCPlanBuilder.Welcome">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".PlanViewActivity"
            android:exported="false"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/Theme.UIUCPlanBuilder.NoActionBar" />

        <activity
            android:name=".NewPlanActivity"
            android:exported="false"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/Theme.UIUCPlanBuilder.NoActionBar" />

        <activity
            android:name=".QuestionnaireActivity"
            android:exported="false"
            android:parentActivityName=".NewPlanActivity"
            android:theme="@style/Theme.UIUCPlanBuilder.NoActionBar" />

        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.UIUCPlanBuilder.NoActionBar" />

        <activity
            android:name=".CompareActivity"
            android:exported="false"
            android:parentActivityName=".HomeActivity"
            android:theme="@style/Theme.UIUCPlanBuilder.NoActionBar" />

    </application>

</manifest>
