<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Core class pacing"
        android:textAppearance="?attr/textAppearanceSubtitle1"
        android:textColor="@color/declared_forest" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="How many major requirements to schedule per semester"
        android:textAppearance="?attr/textAppearanceCaption"
        android:textColor="@color/declared_sage" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_pacing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pacing_relaxed"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Relaxed\n2 / sem" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pacing_normal"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Normal\n3 / sem" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pacing_fast"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Fast\n4 / sem" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="20dp"
        android:background="#E0E0E0" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Semester credit limit"
        android:textAppearance="?attr/textAppearanceSubtitle1"
        android:textColor="@color/declared_forest" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Higher limits allow more gen-eds and electives per semester"
        android:textAppearance="?attr/textAppearanceCaption"
        android:textColor="@color/declared_sage" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_load"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_load_light"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Light\n15 cr" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_load_standard"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Standard\n18 cr" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_load_heavy"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Heavy\n20 cr" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

</LinearLayout>
