<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/declared_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <!-- Start date -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/declared_paper">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="When are you starting?"
                    android:textAppearance="?attr/textAppearanceSubtitle1"
                    android:textColor="@color/declared_forest" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/profile_semester_layout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Semester">

                        <AutoCompleteTextView
                            android:id="@+id/profile_semester_dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:padding="14dp"
                            android:textAppearance="?attr/textAppearanceBody1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <View android:layout_width="12dp" android:layout_height="1dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/profile_year_layout"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Year">

                        <AutoCompleteTextView
                            android:id="@+id/profile_year_dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:padding="14dp"
                            android:textAppearance="?attr/textAppearanceBody1" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Goals -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/declared_paper">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="What are your goals?"
                    android:textAppearance="?attr/textAppearanceSubtitle1"
                    android:textColor="@color/declared_forest" />

                <CheckBox
                    android:id="@+id/profile_goal_graduate_early"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Graduate as early as possible"
                    android:textAppearance="?attr/textAppearanceBody1" />

                <CheckBox
                    android:id="@+id/profile_goal_minor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Add a minor"
                    android:textAppearance="?attr/textAppearanceBody1" />

                <CheckBox
                    android:id="@+id/profile_goal_double_major"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Double major or dual degree"
                    android:textAppearance="?attr/textAppearanceBody1" />

                <CheckBox
                    android:id="@+id/profile_goal_study_abroad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Study abroad (one semester)"
                    android:textAppearance="?attr/textAppearanceBody1" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Gen-ed preferences -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/declared_paper">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gen-ed preferences"
                    android:textAppearance="?attr/textAppearanceSubtitle1"
                    android:textColor="@color/declared_forest" />

                <CheckBox
                    android:id="@+id/profile_pref_online_gen_eds"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="I prefer online sections for gen-ed courses"
                    android:textAppearance="?attr/textAppearanceBody1" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:padding="14dp"
            android:text="Save"
            android:textColor="@color/declared_cream"
            app:backgroundTint="@color/declared_forest"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>