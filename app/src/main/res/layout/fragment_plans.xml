<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/declared_forest"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Plans"
                android:textAppearance="?attr/textAppearanceHeadline5"
                android:textColor="@color/declared_butter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Saved academic plans"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="@color/declared_cream" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_compare"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compare"
            android:textColor="@color/declared_cream"
            app:strokeColor="@color/declared_cream" />

    </LinearLayout>

    <!-- Content area (fills remaining height, contains list OR empty state + FAB) -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Empty state (centered) -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingBottom="80dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No saved plans yet"
                android:textColor="#888888"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:paddingHorizontal="32dp"
                android:text="Tap the + button to build your first plan"
                android:textColor="#AAAAAA"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Plans list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_plans"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="88dp"
            android:visibility="gone" />

        <!-- New Plan FAB -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_new_plan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:text="New Plan"
            app:backgroundTint="@color/declared_butter"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="@color/declared_deep" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</LinearLayout>
