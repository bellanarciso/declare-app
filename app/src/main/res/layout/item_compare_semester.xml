<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="8dp">

    <!-- Semester label bar -->
    <TextView
        android:id="@+id/text_semester_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/declared_forest"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:textAppearance="?attr/textAppearanceSubtitle2"
        android:textColor="@color/declared_cream" />

    <!-- Side-by-side columns -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Plan A courses -->
        <LinearLayout
            android:id="@+id/container_a"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/declared_paper"
            android:paddingVertical="4dp" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/declared_sage" />

        <!-- Plan B courses -->
        <LinearLayout
            android:id="@+id/container_b"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@color/declared_paper"
            android:paddingVertical="4dp" />

    </LinearLayout>

</LinearLayout>